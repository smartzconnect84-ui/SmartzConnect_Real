# ─── Client-side (VITE_ prefix, safe to expose) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_URL=http://localhost:5000
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id_here
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key_here
VITE_STREAM_API_KEY=your_getstream_api_key_here

# ─── Server-side secrets (set in Supabase Edge Function secrets, NOT here) ───
# These must NEVER be stored in this file or committed to git.
# Set them via: supabase secrets set KEY=value
#
# ONESIGNAL_API_KEY=os_v2_app_...
# TURNSTILE_SECRET_KEY=0x4AAAA...
# STREAM_API_SECRET=your_stream_api_secret
# RESEND_API_KEY=re_...
